[user]
	name = Shivraj
	email = shivrajsoni09022005@gmail.com
	signingkey = FB6F60EAB9E58AF7

[init]
	defaultBranch = main

[core]
	pager = delta
	compression = 9
	whitespace = error
	preloadindex = true

[pull]
	rebase = true
	default = current

[push]
	autoSetupRemote = true
	default = current

[rebase]
	autoStash = true

[diff]
	context = 3
	renames = copies
	interHunkContext = 10
	colorMoved = default

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true

[merge]
	conflictStyle = zdiff3

[status]
	showUntrackedFiles = all
	showStash = true
	branch = true

[commit]
	gpgsign = true

[alias]
	uncommit = reset --soft HEAD~1
	unstage = restore --staged .
	last = log -1 HEAD --stat
	graph = log --graph --oneline --all --decorate
