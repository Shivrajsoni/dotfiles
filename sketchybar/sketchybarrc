#!/usr/bin/env bash

export SKETCHYBAR_CONFIG_DIR="/Users/shivraj/dotfiles/sketchybar"
source "$SKETCHYBAR_CONFIG_DIR/variables.sh"

sketchybar --bar height=$BAR_HEIGHT \
  color=$BAR_COLOR \
  corner_radius=$BAR_CORNER_RADIUS \
  y_offset=$BAR_Y_OFFSET \
  margin=$BAR_MARGIN \
  blur_radius=$BAR_BLUR \
  sticky=on \
  position=top \
  shadow=$SHADOW \
  topmost=window \
  --default updates=when_shown \
  icon.font="$FONT:Bold:14.0" \
  icon.color=$ICON_COLOR \
  icon.padding_left=12 \
  icon.padding_right=6 \
  label.font="$FONT:Bold:13.0" \
  label.color=$LABEL_COLOR \
  label.padding_left=6 \
  label.padding_right=12 \
  background.height=$ITEM_HEIGHT \
  background.corner_radius=$ITEM_CORNER_RADIUS \
  background.color=$SURFACE0 \
  background.border_color=$SURFACE1 \
  background.border_width=$BORDER_WIDTH \
  background.padding_left=6 \
  background.padding_right=6 \
  background.shadow.drawing=$SHADOW \
  popup.background.border_width=$BORDER_WIDTH \
  popup.background.corner_radius=$ITEM_CORNER_RADIUS \
  popup.background.border_color=$SURFACE1 \
  popup.background.color=$BASE \
  popup.background.shadow.drawing=$SHADOW

# Left side (spaces, front_app, then todo in the empty portion)
sketchybar --add event todo_update
source "$ITEM_DIR/spaces.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/todo.sh"

# Right side
source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/cpu.sh"

#################### Finalizing Setup ####################

sketchybar --hotload true
sketchybar --trigger todo_update
sketchybar --update

echo "sketchybar configuration loaded.."
